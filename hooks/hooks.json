{
  "description": "Auto dream + extract: SessionEnd consolidates memory; Stop incrementally extracts after each assistant message.",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/trigger.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/trigger-extract.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
